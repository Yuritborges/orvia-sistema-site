---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FeatureCard from '../components/FeatureCard.astro';
import ScreenshotGallery from '../components/ScreenshotGallery.astro';
import Pricing from '../components/Pricing.astro';
import CTA from '../components/CTA.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import { PROBLEMS, FEATURES, ONBOARDING, DIFFERENTIALS, SITE, LINKS } from '../data/site';
---

<Layout>
  <Header />

  <main id="conteudo-principal">
    <Hero />

    <!-- O Problema -->
    <section class="py-20 sm:py-28 surface-alt" aria-labelledby="problema-heading">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          id="problema-heading"
          title="O problema"
          centered={false}
          subtitle="Equipes de compras em obras enfrentam os mesmos gargalos — planilhas que não conversam, processos manuais e zero visibilidade unificada."
        />
        <ul class="mx-auto grid max-w-3xl gap-4 sm:grid-cols-2" role="list">
          {
            PROBLEMS.map((problem) => (
              <li class="card flex items-start gap-3 p-5">
                <span
                  class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full text-xs font-bold text-white"
                  style="background: var(--color-orvia-orange);"
                  aria-hidden="true"
                >
                  !
                </span>
                <span class="text-sm leading-relaxed text-secondary">{problem}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- A Solução -->
    <section id="funcionalidades" class="py-20 sm:py-28" aria-labelledby="funcionalidades-heading">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          id="funcionalidades-heading"
          title="A solução — módulos do ORVIA"
          subtitle="Um sistema desktop integrado que centraliza o fluxo de compras — do pedido à cotação, da ferramenta à locação."
        />
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {FEATURES.map((feature) => (
            <FeatureCard
              title={feature.title}
              description={feature.description}
              icon={feature.icon}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Galeria -->
    <ScreenshotGallery />

    <!-- Diferenciais -->
    <section class="py-20 sm:py-28" aria-labelledby="diferenciais-heading">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          id="diferenciais-heading"
          title="Por que o ORVIA"
          subtitle="Mais que um software: um sistema feito para a rotina de compras das suas obras, com gente por trás para implantar e dar suporte."
        />
        <div class="grid gap-5 sm:grid-cols-3">
          {DIFFERENTIALS.map((item) => (
            <FeatureCard
              title={item.title}
              description={item.description}
              icon={item.icon}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Implantação -->
    <section id="implantacao" class="py-20 sm:py-28 surface-alt" aria-labelledby="implantacao-heading">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          id="implantacao-heading"
          title="Como colocamos o ORVIA na sua operação"
          subtitle="Do primeiro contato ao dia a dia rodando — você é acompanhado em cada etapa."
        />
        <ol class="mx-auto grid max-w-4xl gap-4 sm:grid-cols-2 lg:grid-cols-4" role="list">
          {
            ONBOARDING.map((step, index) => (
              <li class="card p-5">
                <div class="mb-3 flex items-center gap-3">
                  <span
                    class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg text-sm font-bold text-white"
                    style="background: var(--color-orvia-blue);"
                  >
                    {index + 1}
                  </span>
                  <h3 class="font-bold">{step.title}</h3>
                </div>
                <p class="text-sm leading-relaxed text-secondary">{step.description}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <!-- Personalização -->
    <section class="py-20 sm:py-28" aria-labelledby="personalizacao-heading">
      <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
        <div class="section-accent mx-auto mb-4"></div>
        <h2 id="personalizacao-heading" class="font-serif mb-4 text-3xl sm:text-4xl">
          A sua marca, o seu processo
        </h2>
        <p class="text-secondary leading-relaxed">
          O ORVIA se adapta à sua empresa: documentos com a sua logo e das suas faturadoras,
          campos e fluxos ajustados à forma como você compra, e operação multi-obra ou
          multi-empresa quando o seu negócio exigir. Você não molda a sua rotina ao sistema —
          o sistema acompanha a sua rotina.
        </p>
      </div>
    </section>

    <!-- Planos -->
    <Pricing />

    <!-- Sobre o autor -->
    <section id="sobre" class="py-20 sm:py-28" aria-labelledby="sobre-heading">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="card mx-auto max-w-2xl p-8 text-center sm:p-10">
          <div
            class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full text-2xl font-bold text-white"
            style="background: linear-gradient(135deg, var(--color-orvia-blue), var(--color-orvia-orange));"
            aria-hidden="true"
          >
            MI
          </div>
          <h2 id="sobre-heading" class="font-serif mb-2 text-2xl sm:text-3xl">Quem está por trás do ORVIA</h2>
          <p class="mb-6 text-secondary leading-relaxed">
            O ORVIA é desenvolvido por {SITE.author}, com foco em soluções práticas para a
            operação de construtoras. O sistema nasceu da rotina real de compras em obras —
            por isso o atendimento é direto com quem entende do produto e do seu dia a dia,
            da implantação ao suporte.
          </p>
          <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
            <a
              href={LINKS.linkedin}
              class="btn btn-secondary w-full sm:w-auto"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 114.128 0 2.063 2.063 0 01-2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
              LinkedIn
            </a>
            <a
              href={LINKS.whatsapp}
              class="btn btn-primary w-full sm:w-auto"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
              WhatsApp
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <CTA variant="footer" />

    <!-- Contato -->
    <ContactForm />
  </main>

  <Footer />
</Layout>
