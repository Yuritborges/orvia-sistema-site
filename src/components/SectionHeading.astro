---
interface Props {
  title: string;
  subtitle?: string;
  id?: string;
  centered?: boolean;
}

const { title, subtitle, id, centered = true } = Astro.props;
---

<div class:list={['mb-10', centered && 'text-center']}>
  <div class:list={['section-accent mb-4', centered && 'mx-auto']}></div>
  <h2 id={id} class="font-serif mb-3 text-3xl sm:text-4xl">{title}</h2>
  {subtitle && (
    <p class:list={['max-w-2xl text-secondary', centered && 'mx-auto']}>{subtitle}</p>
  )}
</div>
