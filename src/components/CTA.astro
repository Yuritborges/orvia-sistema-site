---
import { LINKS } from '../data/site';

interface Props {
  variant?: 'default' | 'footer';
}

const { variant = 'default' } = Astro.props;
const isFooter = variant === 'footer';
---

<section
  id="contato"
  class:list={[
    isFooter ? 'py-12' : 'py-16 sm:py-20',
  ]}
  aria-labelledby={isFooter ? 'cta-footer-heading' : 'cta-heading'}
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div
      class="relative overflow-hidden rounded-xl px-6 py-12 text-center sm:px-12 sm:py-16"
      style="background: linear-gradient(160deg, var(--color-orvia-blue) 0%, var(--color-orvia-blue-dark) 100%);"
    >
      <!-- Decoração -->
      <div
        class="pointer-events-none absolute -bottom-16 -left-16 h-48 w-48 rounded-full opacity-20"
        style="background: var(--color-orvia-orange);"
        aria-hidden="true"
      ></div>

      <h2
        id={isFooter ? 'cta-footer-heading' : 'cta-heading'}
        class="font-serif relative mb-4 text-3xl text-white sm:text-4xl"
      >
        {isFooter ? 'Experimente a demo agora' : 'Pronto para ver na prática?'}
      </h2>
      <p class="relative mx-auto mb-8 max-w-xl text-white/85">
        Baixe o instalador Windows, explore com dados fictícios e veja o código-fonte no GitHub.
      </p>

      <div class="relative flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={LINKS.release}
          class="btn btn-primary w-full sm:w-auto"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Baixar demo (Windows)
        </a>
        <a
          href={LINKS.github}
          class="btn w-full border-2 border-white/30 bg-white/10 text-white hover:bg-white/20 sm:w-auto"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
          Ver código no GitHub
        </a>
      </div>

      <p class="relative mt-6 text-sm text-white/70">
        Versão demonstração para portfólio · Dados fictícios · Código aberto
      </p>
    </div>
  </div>
</section>
