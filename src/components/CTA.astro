---
import { waLink } from '../data/site';

interface Props {
  variant?: 'default' | 'footer';
}

const { variant = 'default' } = Astro.props;
const isFooter = variant === 'footer';

const demoMessage = waLink(
  'Olá! Gostaria de agendar uma demonstração do ORVIA para a minha construtora.'
);
---

<section
  class:list={[
    isFooter ? 'py-12' : 'py-16 sm:py-20',
  ]}
  aria-labelledby={isFooter ? 'cta-footer-heading' : 'cta-heading'}
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div
      class="relative overflow-hidden rounded-2xl border-t-4 px-6 py-14 text-center shadow-xl sm:px-12 sm:py-20"
      style="background: linear-gradient(135deg, #21566b 0%, var(--color-orvia-blue) 45%, var(--color-orvia-blue-dark) 100%); border-top-color: var(--color-orvia-orange);"
    >
      <!-- Glows decorativos (limpos, sem sujar o fundo) -->
      <div
        class="pointer-events-none absolute -top-24 -right-16 h-72 w-72 rounded-full blur-3xl"
        style="background: radial-gradient(circle, rgba(230,126,34,0.45) 0%, transparent 70%);"
        aria-hidden="true"
      ></div>
      <div
        class="pointer-events-none absolute -bottom-24 -left-20 h-72 w-72 rounded-full blur-3xl"
        style="background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 70%);"
        aria-hidden="true"
      ></div>

      <span
        class="relative mb-4 inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-white/90"
      >
        Atendimento direto com quem desenvolve
      </span>
      <h2
        id={isFooter ? 'cta-footer-heading' : 'cta-heading'}
        class="relative mb-4 text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl"
      >
        {isFooter ? 'Leve o ORVIA para as suas obras' : 'Pronto para organizar as suas compras?'}
      </h2>
      <p class="relative mx-auto mb-8 max-w-xl text-base text-white/85 sm:text-lg">
        Agende uma demonstração sem compromisso. Mostramos o sistema funcionando e montamos
        uma proposta para a realidade da sua construtora.
      </p>

      <div class="relative flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={demoMessage}
          class="btn btn-primary w-full sm:w-auto"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
          </svg>
          Falar no WhatsApp
        </a>
        <a
          href="#contato"
          class="btn w-full border-2 border-white/30 bg-white/10 text-white hover:bg-white/20 sm:w-auto"
        >
          Enviar mensagem
        </a>
      </div>

      <p class="relative mt-6 text-sm text-white/70">
        Resposta no mesmo dia útil · Implantação e treinamento inclusos
      </p>
    </div>
  </div>
</section>
