---
import { PLANS, waLink } from '../data/site';
---

<section id="planos" class="py-20 sm:py-28" aria-labelledby="planos-heading">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mb-10 text-center">
      <span class="eyebrow">Planos</span>
      <h2 id="planos-heading" class="font-serif mb-3 text-3xl sm:text-4xl">
        Escolha o plano da sua operação
      </h2>
      <p class="mx-auto max-w-2xl text-secondary">
        Do controle de uma obra à operação multi-empresa. Cada implantação é dimensionada
        com você — fale com a gente e receba uma proposta sob medida.
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-3 md:items-start">
      {
        PLANS.map((plan) => (
          <article
            class:list={[
              'card flex h-full flex-col p-6 sm:p-7',
              plan.featured && 'plan-featured md:-mt-3 md:pb-9',
            ]}
          >
            <h3 class="text-xl font-bold">{plan.name}</h3>
            <p class="mt-1 text-sm text-secondary">{plan.tagline}</p>

            <p class="mt-4 mb-5">
              <span class="text-2xl font-extrabold" style="color: var(--color-orvia-orange);">
                Sob consulta
              </span>
            </p>

            <ul class="mb-6 flex-1 space-y-2.5" role="list">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-2 text-sm text-secondary">
                  <svg
                    class="mt-0.5 h-4 w-4 shrink-0"
                    style="color: var(--color-orvia-orange);"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <a
              href={waLink(plan.whatsapp)}
              class:list={['btn w-full', plan.featured ? 'btn-primary' : 'btn-secondary']}
              target="_blank"
              rel="noopener noreferrer"
            >
              {plan.cta}
            </a>
          </article>
        ))
      }
    </div>

    <p class="mx-auto mt-8 max-w-2xl text-center text-sm text-muted">
      Valores sob consulta. A escolha do plano não gera cobrança automática — primeiro
      conversamos para entender a sua operação e montar a proposta.
    </p>
  </div>
</section>
