---
import { SITE, ASSETS, waLink } from '../data/site';

const demoMessage = waLink(
  'Olá! Gostaria de agendar uma demonstração do ORVIA para a minha construtora.'
);
---

<section id="inicio" class="hero-bg relative overflow-hidden pt-24 pb-16 sm:pt-28 sm:pb-24">
  <!-- Decoração sutil -->
  <div
    class="pointer-events-none absolute -top-32 -right-32 h-96 w-96 rounded-full opacity-[0.06]"
    style="background: radial-gradient(circle, var(--color-orvia-orange) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Texto -->
      <div class="fade-in text-center lg:text-left">
        <img
          src={ASSETS.logoLight}
          alt="ORVIA — Pedidos de Compra"
          width="220"
          height="60"
          class="mx-auto mb-6 h-auto w-48 lg:mx-0 logo-light"
          loading="eager"
        />
        <img
          src={ASSETS.logoDark}
          alt="ORVIA — Pedidos de Compra"
          width="220"
          height="60"
          class="mx-auto mb-6 hidden h-auto w-48 lg:mx-0 logo-dark"
          loading="eager"
        />

        <h1 class="font-serif mb-4 text-4xl leading-tight sm:text-5xl lg:text-[3.25rem]">
          {SITE.tagline}
        </h1>

        <p class="mb-6 text-lg text-secondary sm:text-xl">
          O sistema de gestão de compras pensado para construtoras: pedidos, cotações,
          ferramentas e locações de todas as obras em um só lugar.
        </p>

        <div class="mb-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-center lg:justify-start">
          <a
            href={demoMessage}
            class="btn btn-primary w-full sm:w-auto"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
            Solicitar demonstração
          </a>
          <a href="#planos" class="btn btn-secondary w-full sm:w-auto">
            Ver planos
          </a>
        </div>

        <div class="badge-demo mx-auto lg:mx-0">
          <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          Software para construção civil · implantação e suporte inclusos
        </div>

        <dl class="mt-8 grid max-w-md grid-cols-3 gap-4 border-t border-[var(--border-color)] pt-6 text-center mx-auto lg:mx-0 lg:text-left">
          <div class="flex flex-col-reverse">
            <dt class="text-xs font-medium text-muted sm:text-sm">módulos integrados</dt>
            <dd class="m-0 text-2xl font-extrabold sm:text-3xl" style="color: var(--color-orvia-orange);">6</dd>
          </div>
          <div class="flex flex-col-reverse">
            <dt class="text-xs font-medium text-muted sm:text-sm">offline</dt>
            <dd class="m-0 text-2xl font-extrabold sm:text-3xl" style="color: var(--color-orvia-orange);">100%</dd>
          </div>
          <div class="flex flex-col-reverse">
            <dt class="text-xs font-medium text-muted sm:text-sm">fornecedores/cotação</dt>
            <dd class="m-0 text-2xl font-extrabold sm:text-3xl" style="color: var(--color-orvia-orange);">3</dd>
          </div>
        </dl>
      </div>

      <!-- Vídeo do mascote (fundo transparente) -->
      <div class="fade-in relative mx-auto w-full max-w-xl lg:max-w-none">
        <div id="hero-video-wrap" class="hero-video-wrap relative mx-auto w-full" data-muted="true">
          <video
            id="hero-video"
            class="hero-video mx-auto w-full"
            autoplay
            muted
            loop
            playsinline
            preload="auto"
            aria-label="Mascote ORVIA apresentando o sistema"
          >
            <source src={ASSETS.heroVideoWebm} type="video/webm" />
            <source src={ASSETS.heroVideoMp4} type="video/mp4" />
          </video>

          <button
            id="hero-video-sound"
            class="hero-sound-btn"
            type="button"
            aria-label="Ativar ou desativar o som do vídeo"
          >
            <!-- ícone: mudo -->
            <svg class="hero-sound-icon icon-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 5 6 9H3v6h3l5 4V5z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 9l4 6m0-6l-4 6" />
            </svg>
            <!-- ícone: com som -->
            <svg class="hero-sound-icon icon-on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 5 6 9H3v6h3l5 4V5z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 8.5a5 5 0 010 7M18.5 6a8 8 0 010 12" />
            </svg>
            <span class="hero-sound-hint">Passe o mouse para ouvir</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Fundo branco no hero para reforçar o efeito 3D do mascote flutuando */
  .hero-bg {
    background: #ffffff;
  }
  [data-theme='dark'] .hero-bg {
    background: var(--bg-page);
  }

  .hero-video-wrap {
    max-width: 560px;
  }

  .hero-video {
    display: block;
    max-height: 560px;
    object-fit: contain;
    /* WebM transparente flutua sobre o fundo; sem caixa/borda */
    background: transparent;
  }

  .hero-sound-btn {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.7rem;
    border-radius: 9999px;
    border: 1px solid var(--border-color);
    background: color-mix(in srgb, var(--bg-surface) 88%, transparent);
    color: var(--text-secondary);
    cursor: pointer;
    backdrop-filter: blur(6px);
    box-shadow: var(--shadow);
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease),
      background var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .hero-sound-btn:hover {
    color: var(--color-orvia-orange);
    border-color: var(--color-orvia-orange);
    transform: translateY(-1px);
  }
  .hero-sound-icon {
    width: 1.15rem;
    height: 1.15rem;
    flex-shrink: 0;
  }
  .hero-sound-hint {
    font-size: 0.75rem;
    font-weight: 600;
    white-space: nowrap;
  }
  /* Alterna os ícones conforme o estado (data-muted no wrapper) */
  .hero-video-wrap[data-muted='true'] .icon-on {
    display: none;
  }
  .hero-video-wrap[data-muted='false'] .icon-muted {
    display: none;
  }
  /* Quando já está com som, encurta o texto */
  .hero-video-wrap[data-muted='false'] .hero-sound-hint {
    display: none;
  }

  .logo-dark {
    display: none;
  }
  [data-theme='dark'] .logo-light {
    display: none;
  }
  [data-theme='dark'] .logo-dark {
    display: block;
  }
  @media (min-width: 1024px) {
    [data-theme='dark'] .logo-dark {
      display: block;
    }
  }
</style>

<script>
  const wrap = document.getElementById('hero-video-wrap');
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  const btn = document.getElementById('hero-video-sound');

  if (wrap && video && btn) {
    // true = usuário fixou o som ligado (clique); ignora o hover
    let locked = false;

    const setMuted = (muted: boolean) => {
      video.muted = muted;
      wrap.dataset.muted = String(muted);
      if (!muted) {
        video.play().catch(() => {});
      }
    };

    setMuted(true);

    // Hover: passa o mouse => liga o som; tira o mouse => muta
    wrap.addEventListener('mouseenter', () => {
      if (!locked) setMuted(false);
    });
    wrap.addEventListener('mouseleave', () => {
      if (!locked) setMuted(true);
    });

    // Clique no botão: fixa/solta o som (útil também no celular, onde não há hover)
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      locked = !locked;
      setMuted(!locked);
    });
  }
</script>
