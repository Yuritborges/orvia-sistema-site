---
import { SITE, LINKS, ASSETS } from '../data/site';
---

<footer class="border-t border-[var(--border-color)] py-10" style="background-color: var(--bg-surface-alt);">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      <!-- Marca -->
      <div>
        <div class="mb-3 flex items-center gap-2">
          <img src={ASSETS.icon} alt="" width="32" height="32" class="h-8 w-8" aria-hidden="true" />
          <span class="text-lg font-bold">ORVIA</span>
        </div>
        <p class="mb-2 text-sm font-medium text-secondary">{SITE.tagline}</p>
        <p class="text-xs text-muted">
          ORVIA — {SITE.brandMeaning}
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-muted">Links</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href={LINKS.github} class="text-secondary hover:text-[var(--color-orvia-orange)]" target="_blank" rel="noopener noreferrer">
              GitHub — Repositório
            </a>
          </li>
          <li>
            <a href={LINKS.release} class="text-secondary hover:text-[var(--color-orvia-orange)]" target="_blank" rel="noopener noreferrer">
              Release v{SITE.version}
            </a>
          </li>
          <li>
            <a href={LINKS.linkedin} class="text-secondary hover:text-[var(--color-orvia-orange)]" target="_blank" rel="noopener noreferrer">
              LinkedIn
            </a>
          </li>
          <li>
            <a href={LINKS.whatsapp} class="text-secondary hover:text-[var(--color-orvia-orange)]" target="_blank" rel="noopener noreferrer">
              WhatsApp
            </a>
          </li>
        </ul>
      </div>

      <!-- Aviso legal -->
      <div>
        <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-muted">Aviso</h3>
        <p class="text-sm leading-relaxed text-secondary">
          Versão demonstração para portfólio. Todos os dados exibidos são fictícios — nenhum dado real de clientes.
          Código disponível no GitHub.
        </p>
      </div>
    </div>

    <div class="mt-8 border-t border-[var(--border-color)] pt-6 text-center text-sm text-muted">
      <p>
        © {SITE.year} · ORVIA · {SITE.tagline}
      </p>
      <p class="mt-1">
        Desenvolvido por{' '}
        <a
          href={LINKS.linkedin}
          class="font-medium text-[var(--color-orvia-orange)] hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          {SITE.author}
        </a>
      </p>
    </div>
  </div>
</footer>
