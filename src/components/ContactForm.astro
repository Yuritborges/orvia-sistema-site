---
import { FORM_ENDPOINT, WHATSAPP_NUMBER, LINKS, PLANS } from '../data/site';
---

<section id="contato" class="py-20 sm:py-28 surface-alt" aria-labelledby="contato-heading">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="mb-10 text-center">
      <div class="section-accent mx-auto mb-4"></div>
      <h2 id="contato-heading" class="font-serif mb-3 text-3xl sm:text-4xl">
        Fale com a gente
      </h2>
      <p class="mx-auto max-w-2xl text-secondary">
        Conte um pouco sobre a sua operação. Retornamos com uma demonstração e uma
        proposta sob medida — sem compromisso.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-5">
      <!-- Formulário -->
      <form
        id="contact-form"
        class="card lg:col-span-3 flex flex-col gap-4 p-6 sm:p-8"
        action={FORM_ENDPOINT || undefined}
        method="POST"
        data-whatsapp={WHATSAPP_NUMBER}
        data-has-endpoint={FORM_ENDPOINT ? 'true' : 'false'}
      >
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="flex flex-col gap-1.5">
            <label for="cf-nome" class="text-sm font-medium">Nome*</label>
            <input id="cf-nome" name="nome" type="text" required autocomplete="name" class="form-input" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="cf-empresa" class="text-sm font-medium">Empresa*</label>
            <input id="cf-empresa" name="empresa" type="text" required autocomplete="organization" class="form-input" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="cf-telefone" class="text-sm font-medium">Telefone / WhatsApp*</label>
            <input id="cf-telefone" name="telefone" type="tel" required autocomplete="tel" placeholder="(11) 99999-9999" class="form-input" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="cf-email" class="text-sm font-medium">E-mail</label>
            <input id="cf-email" name="email" type="email" autocomplete="email" class="form-input" />
          </div>
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="cf-plano" class="text-sm font-medium">Plano de interesse</label>
          <select id="cf-plano" name="plano" class="form-input">
            <option value="">Ainda não sei / quero orientação</option>
            {PLANS.map((plan) => (
              <option value={plan.name}>{plan.name}</option>
            ))}
          </select>
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="cf-mensagem" class="text-sm font-medium">Mensagem</label>
          <textarea id="cf-mensagem" name="mensagem" rows="4" class="form-input" placeholder="Quantas obras você gerencia? O que mais precisa organizar?"></textarea>
        </div>

        <button type="submit" class="btn btn-primary w-full sm:w-auto sm:self-start">
          Enviar mensagem
        </button>

        <p id="cf-status" class="text-sm" role="status" aria-live="polite"></p>
      </form>

      <!-- Canais diretos -->
      <aside class="lg:col-span-2 flex flex-col gap-4">
        <div class="card p-6">
          <h3 class="mb-1 text-lg font-bold">Prefere falar agora?</h3>
          <p class="mb-4 text-sm text-secondary">
            Atendimento direto pelo WhatsApp, com resposta no mesmo dia útil.
          </p>
          <a
            href={LINKS.whatsapp}
            class="btn btn-primary w-full"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            Abrir conversa no WhatsApp
          </a>
        </div>

        <div class="card p-6">
          <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-muted">
            Como funciona
          </h3>
          <ul class="space-y-3 text-sm text-secondary" role="list">
            <li class="flex items-start gap-2">
              <span class="mt-0.5 font-bold text-[var(--color-orvia-orange)]">1.</span>
              <span>Você envia a mensagem ou chama no WhatsApp.</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-0.5 font-bold text-[var(--color-orvia-orange)]">2.</span>
              <span>Agendamos uma demonstração do sistema funcionando.</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-0.5 font-bold text-[var(--color-orvia-orange)]">3.</span>
              <span>Montamos a proposta para a realidade das suas obras.</span>
            </li>
          </ul>
        </div>
      </aside>
    </div>
  </div>
</section>
