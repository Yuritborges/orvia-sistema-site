const path = icons[icon] ?? icons.clipboard;
---

<article class="card p-6">
  <div
    class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl"
    style="background: rgba(230, 126, 34, 0.12); color: var(--color-orvia-orange);"
  >
    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={path} />
    </svg>
  </div>
  <h3 class="mb-2 text-lg font-bold">{title}</h3>
  <p class="text-sm leading-relaxed text-secondary">{description}</p>
</article>
